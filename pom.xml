<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
		 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		 xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">

	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.3.4</version>
		<relativePath/> <!-- lookup parent from repository -->
	</parent>

	<groupId>com.packt.spring.ai</groupId>
	<artifactId>examples-parent</artifactId>
	<version>0.1.0-SNAPSHOT</version>
	<packaging>pom</packaging>

	<modules>
		<module>spring-ai-extensions</module>
		<module>example-one</module>
		<module>audio-transcription-example</module>
		<module>chat-client-example</module>
		<module>chat-model-options-example</module>
		<module>document-etl-example</module>
		<module>embeddings-example</module>
		<module>function-example</module>
		<module>image-generation-example</module>
		<module>metadata-example</module>
		<module>moderation-example</module>
		<module>pre-generated-answers-example</module>
		<module>prompt-example</module>
		<module>similarity-search-example</module>
		<module>streaming-example</module>
		<module>structured-output-converter-example</module>
		<module>tokenizer-example</module>
		<module>opposites-application</module>
		<module>spring-ai-tools</module>
	</modules>

