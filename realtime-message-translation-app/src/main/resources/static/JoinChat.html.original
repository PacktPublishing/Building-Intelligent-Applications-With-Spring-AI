<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Apple Style Chat Form</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(135deg, #f5f7fa, #c3cfe2);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .dialog {
      width: 350px;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      overflow: hidden;
      border: 1px solid #d1d1d6;
    }

    .dialog-header {
      background: linear-gradient(#f9f9f9, #eaeaea);
      border-bottom: 1px solid #d1d1d6;
      padding: 10px 14px;
      font-weight: 600;
      text-align: center;
      font-size: 1rem;
    }

    .dialog-body {
      padding: 20px;
    }

    .dialog-body label {
      display: block;
      margin-bottom: 6px;
      font-size: 0.9rem;
      color: #333;
    }

    .dialog-body input {
      width: 100%;
      padding: 10px;
      margin-bottom: 15px;
      border: 1px solid #ccc;
      border-radius: 8px;
      font-size: 0.95rem;
    }

    .dialog-footer {
      border-top: 1px solid #d1d1d6;
      background: #f9f9f9;
      padding: 12px;
      text-align: right;
    }

    .dialog-footer button {
      background: #007aff;
      border: none;
      color: #fff;
      font-weight: 600;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 0.95rem;
      cursor: pointer;
      transition: background 0.2s;
    }

    .dialog-footer button:hover {
      background: #005ecb;
    }
  </style>
</head>
<body>
  <div class="dialog">
    <div class="dialog-header">Let's Chat</div>
    <form class="dialog-body">
      <label for="name">Your Name</label>
      <input type="text" id="name" name="name" required>

      <label for="url">Your URL</label>
      <input type="url" id="url" name="url" placeholder="https://example.com" required>

      <div class="dialog-footer">
        <button type="submit">Submit</button>
      </div>
    </form>
  </div>
</body>
</html>
